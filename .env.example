# Marina Stee — Environment variables
#
# Copy this file to `.env.local` and fill in the values you want active.
# `.env.local` is gitignored by default.

# ─── Anthropic / Claude agent ───────────────────────────────────────────────
# When set, /api/agent streams real Claude responses for the agent surface.
# When unset, the app falls back to the deterministic simulated agent
# in lib/simulated-agent.ts — every action (charge to account, send message)
# still works end-to-end.
#
# Get a key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Future: backend / database ─────────────────────────────────────────────
# When the Express + Postgres backend lands per CLAUDE.md, the following
# will be required. Stubs for now — not read by the current frontend.

# DATABASE_URL=postgres://user:password@localhost:5432/marina_stee
# SESSION_SECRET=
# QUICKBOOKS_OAUTH_CLIENT_ID=
# QUICKBOOKS_OAUTH_CLIENT_SECRET=
# STRIPE_SECRET_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
