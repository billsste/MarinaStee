# Marina Stee — Environment variables
#
# Copy this file to `.env.local` and fill in the values you want active.
# `.env.local` is gitignored by default.

# ─── Anthropic / Claude agent ───────────────────────────────────────────────
# When set, /api/agent streams real Claude responses for the agent surface.
# When unset, the app falls back to the deterministic simulated agent
# in lib/simulated-agent.ts — every action (charge to account, send message)
# still works end-to-end.
#
# Get a key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Convex (production data layer) ─────────────────────────────────────────
# Full step-by-step setup: docs/convex-setup.md
#
# Set after `npx convex dev` writes them automatically. When NEXT_PUBLIC_CONVEX_URL
# is unset, the ConvexClerkProvider stays out of the way and the app keeps
# reading from lib/mock-data.ts. The moment this is set + the seed is loaded,
# per-page migration can begin (see docs/architecture-convex.md).
#
# Example: https://acoustic-otter-123.convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# Convex deployment identifier for server-side calls + the `npx convex` CLI.
# Written by `npx convex dev` on first run.
# Example: dev:acoustic-otter-123
CONVEX_DEPLOYMENT=

# ─── Clerk (auth + multi-tenant organizations) ──────────────────────────────
# Get these from your Clerk dashboard → API Keys.
# Free tier: ≤10,000 monthly active users + Organizations enabled.
# Enable Organizations in Clerk dashboard → Settings → Organizations.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Issuer domain for the Clerk JWT that Convex's auth.config.ts verifies.
# Found at: Clerk dashboard → Configure → API Keys → "Frontend API" URL.
# Example value: https://moving-falcon-12.clerk.accounts.dev
#
# IMPORTANT: this var must be set in TWO places —
#   1. here in .env.local (so convex/auth.config.ts can read it during `npx convex dev`)
#   2. on the Convex deployment itself:
#        npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-app.clerk.accounts.dev
#      (Convex functions run in their own process — they don't see Next.js env vars.)
CLERK_JWT_ISSUER_DOMAIN=

# Optional: customize sign-in / sign-up URLs
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Postmark (outbound email) ──────────────────────────────────────────────
# When set, every outbound email goes through Postmark. When unset,
# the dispatch layer (lib/notification-dispatch.ts) stamps the comm row
# with error_reason="no_provider_configured" and the demo flow continues.
# Get a token from https://account.postmarkapp.com/api_tokens.
#
# POSTMARK_API_KEY is the canonical name in the wave 3 dispatch layer;
# POSTMARK_SERVER_TOKEN is the legacy alias that lib/adapters/postmark.ts
# also honors so older setups don't break. Set EITHER; setting both is
# safe (API_KEY wins).
#
# Leave blank to disable real send — the dispatcher records the failed
# send on the comm row's error_reason field and the timeline still
# shows the queued message.
POSTMARK_API_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_ADDRESS=no-reply@marinastee.com
# Optional — defaults to "outbound" if not set. Use a sandbox-tier
# stream while testing.
# POSTMARK_MESSAGE_STREAM=outbound

# ─── Twilio (outbound SMS) ──────────────────────────────────────────────────
# Same "leave blank to disable real send" pattern as Postmark. All three
# of (account_sid, auth_token, from_number) must be set for SMS to leave
# our infrastructure — partial config = treated as no provider.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional — public URL Twilio POSTs delivery receipts to. With the
# H2 webhook wave landed, point this at the receiver:
# TWILIO_STATUS_CALLBACK_URL=https://marinastee.com/api/webhooks/twilio

# ─── Webhook ingestion secrets (H2 wave) ────────────────────────────────────
# Postmark webhook signature: when you register the webhook URL in the
# Postmark dashboard you can set a custom token Postmark echoes back as
# `X-Postmark-Webhook-Token` on every event POST. Set the SAME value
# here so `lib/webhook-verify.ts → verifyPostmarkSignature` accepts it.
# Without this set, the /api/webhooks/postmark route returns 200 with
# `ignored: "unverified"` — graceful degradation for the dev/demo
# path where no real Postmark webhook is registered.
POSTMARK_WEBHOOK_SECRET=

# Postmark INBOUND email signature: same scheme as POSTMARK_WEBHOOK_SECRET
# but for the inbound-email server that drives the AP-bill ingest pipeline
# (bills@<marina>.marinastee.com → /api/inbound/postmark/[tenantId]).
# Kept as a separate env so the inbound + outbound webhooks can rotate
# independently. Without it set, /api/inbound/postmark returns 200 with
# `ignored: "unverified"` and no inbound row is written.
POSTMARK_INBOUND_SECRET=

# Twilio doesn't have a per-URL secret — every POST is HMAC-SHA1
# signed against the account's auth token in the `X-Twilio-Signature`
# header. The /api/webhooks/twilio route verifies against
# TWILIO_WEBHOOK_SECRET (when set) or falls back to TWILIO_AUTH_TOKEN.
# Set this only if you want the verify key to differ from the send-
# side auth token (typically only matters when rotating the auth
# token in production — set both for the rotation window).
TWILIO_WEBHOOK_SECRET=

# ─── Future / not used yet ──────────────────────────────────────────────────
# Stripe (deferred — see docs/architecture-convex.md)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
